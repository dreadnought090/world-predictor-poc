4. News Propagation Model

4.1 Information Spread

class NewsPropagation:
    def spread_news(self, news_item, agents):
        # Initial exposure (media consumption patterns)
        exposed_agents = self.expose_to_media(agents, news_item)
        
        # Word-of-mouth spread
        for agent in exposed_agents:
            self.propagate_word_of_mouth(agent, news_item, agents)
        
        # Social media amplification
        self.social_media_spread(news_item, agents)

4.2 Trust & Credibility Factors

class TrustModel:
    def calculate_trust(self, agent, news_source):
        # Political alignment
        alignment = self.calculate_alignment(agent.politics, news_source.politics)
        
        # Historical trust
        historical_trust = agent.trust_history.get(news_source, 0.5)
        
        # Source credibility
        credibility = news_source.credibility_score
        
        return (alignment * 0.3) + (historical_trust * 0.4) + (credibility * 0.3)

